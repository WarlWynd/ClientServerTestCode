# ─────────────────────────────────────────────
#  Game Server Configuration
# ─────────────────────────────────────────────
# Copy this file to server.properties and fill in your values.

# UDP port the server listens on
server.port=9876

# HTTP port for asset file server (used by Developer Console)
server.http.port=9877

# Directory where asset files are stored (relative to working directory)
server.assets.dir=assets

# Comma-separated list of asset subdirectory types to include in the client sync manifest.
# Only these folders will be offered to clients for download.
# Add new types here when you create new asset categories for the client.
server.client.sync.types=sounds,graphics,client

# Static key for uploading assets from the dev machine (leave blank to disable)
# Set this in server.properties, then run: ./gradlew uploadClientJar -PuploadKey=<key>
server.upload.key=

# MySQL / MariaDB connection
db.host=192.168.1.153
db.port=3306
db.name=game_db
db.user=gamemaster
db.password=changeme
